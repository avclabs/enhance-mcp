{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.avclabs/enhance-mcp",
  "description": "HTTP MCP Client-Server for video enhancement API",
  "repository": {
    "url": "https://github.com/avclabs/enhance-mcp",
    "source": "github"
  },
  "version": "0.1.7",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@avclabs.ai/enhance-mcp",
      "version": "0.1.7",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the service",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "HTTP_API_KEY"
        }
      ]
    }
  ]
}